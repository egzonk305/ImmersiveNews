# Supabase — Werte aus: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://deine-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key

# Nur serverseitig (niemals im Frontend verwenden!)
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# Für `npm run db:types`
SUPABASE_PROJECT_ID=deine-project-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
